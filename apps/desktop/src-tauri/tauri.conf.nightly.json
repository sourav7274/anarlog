{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anarlog Nightly",
  "mainBinaryName": "anarlog-nightly",
  "identifier": "com.hyprnote.nightly",
  "plugins": {
    "deep-link": {
      "desktop": { "schemes": ["hyprnote-nightly"] }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://desktop2.hyprnote.com/update/{{target}}-{{arch}}/{{current_version}}?channel=nightly"
      ]
    }
  },
  "bundle": {
    "icon": [
      "icons/stable/32x32.png",
      "icons/stable/128x128.png",
      "icons/stable/128x128@2x.png",
      "icons/stable/icon.icns",
      "icons/stable/icon.ico"
    ],
    "macOS": {
      "files": {
        "Resources/AppIcon.incs": "resources/stable/AppIcon.icns",
        "Resources/Assets.car": "resources/stable/Assets.car"
      },
      "dmg": {
        "background": "assets/dmg-background-nightly.png"
      }
    }
  }
}
