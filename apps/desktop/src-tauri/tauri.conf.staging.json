{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anarlog Staging",
  "mainBinaryName": "anarlog-staging",
  "identifier": "com.hyprnote.staging",
  "plugins": {
    "deep-link": {
      "desktop": { "schemes": ["hyprnote-staging"] }
    },
    "updater": {
      "active": false
    }
  },
  "bundle": {
    "icon": [
      "icons/stable/32x32.png",
      "icons/stable/128x128.png",
      "icons/stable/128x128@2x.png",
      "icons/stable/icon.icns",
      "icons/stable/icon.ico"
    ],
    "macOS": {
      "files": {
        "Resources/AppIcon.incs": "resources/stable/AppIcon.icns",
        "Resources/Assets.car": "resources/stable/Assets.car"
      },
      "dmg": {
        "background": "assets/dmg-background-staging.png"
      }
    }
  }
}
